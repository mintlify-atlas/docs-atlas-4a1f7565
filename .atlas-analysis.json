  "keyFeatures": [
    "Jellyfin, Plex, and Emby integration with user import and authentication",
    "Sonarr and Radarr integration for automatic media acquisition",
    "Customizable media request system for movies and TV shows",
    "Granular permission and user management system",
    "Multi-channel notification support (Discord, Slack, Email, Telegram, Pushover, etc.)",
    "Watchlist and blocklist management",
    "Support for SQLite and PostgreSQL databases",
    "Mobile-friendly responsive UI",
    "Docker and Kubernetes deployment support",
    "Override rules for automatic request routing"
  ],
  "publicApiSurface": [
    "GET /api/v1/search",
    "GET /api/v1/request",
    "POST /api/v1/request",
    "PUT /api/v1/request/{requestId}",
